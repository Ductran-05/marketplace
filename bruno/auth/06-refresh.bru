meta {
  name: 06 Refresh Token
  type: http
  seq: 6
}

post {
  url: {{host}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refreshToken": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setEnvVar("accessToken", res.body.accessToken);
    bru.setEnvVar("refreshToken", res.body.refreshToken);
  }
}

docs {
  Rotation: token mới tự ghi đè vào environment. Token cũ đã bị revoke phía server.
}
